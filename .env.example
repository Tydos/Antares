# Vercel Blob
BLOB_READ_WRITE_TOKEN=

# Hugging Face Inference API (embeddings — required)
# https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=
# Optional: override model id or full inference URL (InferenceClient)
# HUGGINGFACE_INFERENCE_URL=

# Elasticsearch
ES_HOST=http://elasticsearch:9200   # use http://localhost:9200 for local dev outside Docker
INDEX_NAME=pdf-index

# Gemini (required for LLM question-answering step)
GEMINI_API_KEY=                # get from https://aistudio.google.com/app/apikey
