# PostgreSQL. Set DATABASE_URL in .env (not committed).
DATABASE_URL=postgresql://

# Vercel Blob (backend — mints client tokens)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw

# Hugging Face Inference API (embeddings and LLM)
HF_TOKEN=hf_y
HF_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
HF_LLM_MODEL=meta-llama/Llama-3.2-1B-Instruct
