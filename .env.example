# MinIO
MINIO_HOST=minio:9000          # use localhost:9000 for local dev outside Docker
MINIO_ACCESS_KEY=              # MinIO root user
MINIO_SECRET_KEY=              # MinIO root password (min 8 chars)
MINIO_SECURE=false             # set true if MinIO is behind HTTPS
BUCKET_NAME=pdf-files

# Elasticsearch
ES_HOST=http://elasticsearch:9200   # use http://localhost:9200 for local dev outside Docker
INDEX_NAME=pdf-index

# Gemini (required for LLM question-answering step)
GEMINI_API_KEY=                # get from https://aistudio.google.com/app/apikey
